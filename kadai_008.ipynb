        "var = 15\n",
        "\n",
        "# 3の倍数で5の倍数の両方\n",
        "if var % 3 == 0 and var % 5 ==0:\n",
        "  print(\"FizzBuzz\")\n",
        "\n",
        "# 3の倍数\n",
        "elif var % 3 == 0:\n",
        "  print(\"Fizz\")\n",
        "\n",
        "# 5の倍数\n",
        "elif var % 5 == 0:\n",
        "  print(\"Buzz\")\n",
        "\n",
        "# どれにも該当しない\n",
        "else:\n",
        "  print(var)"
