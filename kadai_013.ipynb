      "source": [
        "def calculate_total(price, tax):\n",
        "    tax_included = price * (tax / 100)\n",
        "    total = price + tax_included\n",
        "    return total\n",
        "\n",
        "result = calculate_total(110, 10)\n",
        "print(result)"
      ],
