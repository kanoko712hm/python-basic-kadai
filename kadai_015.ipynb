      "source": [
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(f\"名前: {self.name}, 年齢: {self.age}\")\n",
        "\n",
        "\n",
        "# インスタンスの作成と使用\n",
        "person = Human(\"侍太郎\", 30)\n",
        "\n",
        "# メソッドの呼び出し\n",
        "person.printinfo()"
      ]
    }
  ]
}